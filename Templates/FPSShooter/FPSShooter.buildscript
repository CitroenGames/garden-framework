[solution]
name = FPSShooter
platforms = x64, Linux

include = ${ENGINE_PATH}/Engine/Engine.buildscript

[project:FPSShooter]
type = dll
sources = src/**/*.cpp
headers = src/**/*.hpp
includes = src, src/shared
target_link_libraries(
    PRIVATE EngineSDK
)
defines = RMLUI_SDL_VERSION_MAJOR=3
outdir = bin
multiprocessor = true
simd = AdvancedVectorExtensions2
std = 20
utf8 = true
