[solution]
name = ThirdPerson
platforms = x64, Linux

include = ${ENGINE_PATH}/Engine/Engine.buildscript

[project:ThirdPerson]
type = dll
sources = src/**/*.cpp
headers = src/**/*.hpp
includes = src
target_link_libraries(
    PRIVATE EngineSDK
)
outdir = bin
multiprocessor = true
simd = AdvancedVectorExtensions2
std = 20
utf8 = true
