[project:GardenCLI]
type = exe
outdir = ../../bin/
if(Windows)
{
    subsystem = Console
}
sources = {
    src/**/*.cpp
}
headers = src/**/*.hpp
includes = src, ../../Engine/Thirdparty/tinygltf-2.9.6, ../../Engine/Thirdparty/RmlUi-6.2/Include, ../../Engine/Thirdparty/RmlUi-6.2/Backends
defines = ENGINEGRAPHICS_BUILDING_DLL, RMLUI_SDL_VERSION_MAJOR=3, RMLUI_STATIC_LIB
std = 20
utf8 = true
multiprocessor = true
simd = AdvancedVectorExtensions2
target_link_libraries(RmlUi, freetype, SDL3)
