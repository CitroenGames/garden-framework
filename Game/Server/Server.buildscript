[project:Server]
type = exe
outdir = ../../bin/
if(Windows)
{
    subsystem = Console
}
sources = src/**/*.cpp
headers = src/**/*.h src/**/*.hpp ../shared/**/*.hpp
includes = src, ../shared/
target_link_libraries(
    PRIVATE EngineCore
)
multiprocessor = true
std = 20
utf8 = true
exception_handling = false
buffer_security_check = false
